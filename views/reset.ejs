<%- include("partials/header") %>
    <div class="row justify-content-center">
        <div class="col-xs-12 col-md-6 col-lg-4">
            <form action="/reset/<%= token %>" method="POST">
                <legend class="text-center">Reset password</legend>
                <div class="form-group">
                    <label for="newPassword">New password</label>
                    <input class="form-control" type="password" autofocus name="newPassword" placeholder="New password">
                </div>
                <div class="form-group">
                    <label for="confirmPassword">Confirm password</label>
                    <input class="form-control" type="password" name="confirmPassword" placeholder="Confirm password">
                </div>
                <div class="form-group">
                    <button class="btn btn-lg btn-primary btn-block">Update password</button>
                </div>
            </form>
            <a href="/campgrounds">Go Back</a>
        </div>
    </div>
    <%- include("partials/footer") %>