<%- include("../partials/header"); %>
    <div class="row d-flex justify-content-center">
        <div class="col-md-12 text-center">
            <h1>Create a New Campground</h1>
        </div>
        <div class="col-xs-12 col-md-6 col-lg-4">
            <form class="form-signin" action="/campgrounds" method="POST" enctype="multipart/form-data">
                <input class="form-control" type="text" name="campground[name]" placeholder="name">
                <label class="sr-only" for="image">Img</label>
                <input class="form-control" type="file" id="image" name="img" accept="image/*" required>
                <input class="form-control" type="text" name="campground[description]" placeholder="description">
                <input class="form-control" type="number" name="campground[price]" min="0.00" step="0.01" placeholder="Choose price per night">
                <button class="btn btn-lg btn-primary btn-block">Submit!</button>
            </form>
            <a href="/campgrounds" class="form-signin d-block">Go Back</a>
        </div>
    </div>
    <%- include("../partials/footer"); %>